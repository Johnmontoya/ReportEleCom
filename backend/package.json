    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "mongoose": "^8.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
